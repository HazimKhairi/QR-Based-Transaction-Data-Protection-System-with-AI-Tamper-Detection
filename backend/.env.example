# Copy this file to .env and adjust as needed:
#
#   cp .env.example .env
#
# The defaults below work out-of-the-box with XAMPP MySQL (user=root,
# no password). MAIL is disabled so you don't need SMTP credentials to
# run the demo.

FLASK_ENV=development
FLASK_DEBUG=1
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Demo-safe defaults. Change these in production.
SECRET_KEY=qr-transaction-protection-secret-key-2024
JWT_SECRET_KEY=jwt-secret-key-for-qr-protection-2024
AES_KEY=QRTransactionProtection2024SecureKey!

# Default XAMPP: user=root, password=(blank), db=qr_transaction
# Create the database first:
#   mysql -u root -e "CREATE DATABASE IF NOT EXISTS qr_transaction;"
DATABASE_URL=mysql+pymysql://root:@localhost:3306/qr_transaction

RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100 per hour

OTP_ISSUER_NAME=QR Transaction Protection
OTP_VALID_WINDOW=1
ANOMALY_THRESHOLD=-0.5

# Optional: pin the demo TOTP secret so it survives backend restarts.
# Leave blank to auto-generate on first /demo/* call.
DEMO_TOTP_SECRET=
DEMO_TOTP_ACCOUNT=demo@qrtransaction.my

LOG_LEVEL=INFO
LOG_FILE=app.log
CORS_ORIGINS=*

# Email (Gmail SMTP) — enabled by default with the demo sender account
# below. Replace MAIL_USERNAME / MAIL_PASSWORD with your own Google App
# Password (https://myaccount.google.com/apppasswords) if you'd rather
# send from your own address. Set MAIL_ENABLED=False to disable mail.
MAIL_ENABLED=True
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=tuannuraisha63@gmail.com
MAIL_PASSWORD=ycin czll ynqx kzmk
MAIL_DEFAULT_SENDER=tuannuraisha63@gmail.com
MAIL_DEFAULT_SENDER_NAME=QR Transaction Protection

APP_FRONTEND_URL=http://localhost:3000
